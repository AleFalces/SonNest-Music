# Server
PORT=8080

# Local development database (used when NODE_ENV is not "production")
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=soundnest

# Production database (used when NODE_ENV=production)
DATABASE_URL=postgres://user:password@host:5432/dbname
# Set to "true" to auto-create tables on a fresh production/Docker database
DB_SYNCHRONIZE=false

# Auth
JWT_SECRET=replace-with-a-strong-secret

# Seed admin (created on boot if it doesn't exist)
# Password must satisfy the login form: 8+ chars, an uppercase and a special char.
ADMIN_EMAIL=admin@soundnest.com
ADMIN_PASSWORD=Admin123!

# Mercado Pago (Checkout Pro). Use the TEST access token from your MP
# developer panel ("Credenciales de prueba"); it starts with "TEST-".
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000

# FRONTEND_URL: public base URL of the frontend (Mercado Pago return URLs).
# Defaults to http://localhost:3000; set the https Vercel URL in production.
FRONTEND_URL=http://localhost:3000

# Public base URL of THIS backend, used to build the Mercado Pago webhook
# (notification_url). Leave empty for the browser-only flow. In local dev set it
# to your ngrok https URL (e.g. https://abcd-1234.ngrok-free.app); in production
# set it to the deployed backend URL.
BACKEND_URL=

# Secret to validate Mercado Pago webhook signatures (the "x-signature" header).
# Copy it from the MP panel when you configure the webhook. If left empty,
# signature validation is skipped (local sandbox only).
MP_WEBHOOK_SECRET=

# Cloudinary (admin product-image uploads). Get these from your Cloudinary
# dashboard. The cloud name is the value after "@" in the CLOUDINARY_URL, NOT
# the environment's display name.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
